{
  "name": "launch-runner",
  "displayName": "Launch Runner",
  "description": "JetBrains-style run/debug buttons for VS Code with quick access to launch configurations and tasks",
  "version": "0.0.1",
  "publisher": "RespectMathias",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RespectMathias/LaunchRunner.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "type": "commonjs",
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extensions.js",
  "icon": "assets/run-icon.png",
  "contributes": {
    "commands": [
      {
        "command": "launch-runner.run",
        "title": "Run",
        "icon": "$(run)"
      },
      {
        "command": "launch-runner.debug",
        "title": "Debug",
        "icon": "$(debug)"
      },
      {
        "command": "launch-runner.stop",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "launch-runner.restart",
        "title": "Restart",
        "icon": "$(debug-restart)"
      },
      {
        "command": "launch-runner.selectConfiguration",
        "title": "Select Configuration",
        "icon": "$(kebab-vertical)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "launch-runner.run",
          "when": "launch-runner.hasConfiguration && !launch-runner.isRunning",
          "group": "navigation@-1000"
        },
        {
          "command": "launch-runner.restart",
          "when": "launch-runner.hasConfiguration && launch-runner.isRunning",
          "group": "navigation@-1000"
        },
        {
          "command": "launch-runner.debug",
          "when": "launch-runner.hasConfiguration && !launch-runner.isTaskSelected && !launch-runner.isRunning",
          "group": "navigation@-999"
        },
        {
          "command": "launch-runner.stop",
          "when": "launch-runner.isRunning",
          "group": "navigation@-999"
        },
        {
          "command": "launch-runner.selectConfiguration",
          "group": "navigation@-998"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('./out', { recursive: true, force: true })\"",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "compile": "npm run clean && npm run typecheck && tsc -p ./tsconfig.json",
    "watch": "tsc -p ./tsconfig.json --watch",
    "lint": "eslint src tests",
    "format": "prettier . --write",
    "pretest": "npm run lint && npm run typecheck",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^20.17.57",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1"
  }
}
