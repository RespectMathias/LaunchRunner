{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "outDir": "out",
        "sourceMap": true,
        "types": [
            "node",
            "vscode"
        ]
    },
    "include": [
        "src/**/*.ts"
    ]
}
